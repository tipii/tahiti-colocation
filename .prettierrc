{
  "semi": false,
  "singleQuote": true,
  "trailingComma": "all",
  "printWidth": 100,
  "tabWidth": 2,
  "plugins": ["@ianvs/prettier-plugin-sort-imports"],
  "importOrder": [
    "^react",
    "^next",
    "^expo",
    "^hono",
    "<THIRD_PARTY_MODULES>",
    "^@coloc/(.*)$",
    "^[./]"
  ]
}
