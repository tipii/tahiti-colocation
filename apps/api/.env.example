# ── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://coloc:coloc@localhost:5432/coloc

# ── Better Auth ────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=your-secret-key-at-least-32-characters-long
BETTER_AUTH_URL=http://localhost:3001
WEB_URL=http://localhost:3000

# ── OAuth providers ────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:3001/api/auth/callback/facebook

# ── Cloudflare R2 (object storage) ────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=coloc
R2_PUBLIC_URL=

# ── Email (Brevo) ─────────────────────────────────────────────────────────
BREVO_API_KEY=
EMAIL_FROM_ADDRESS=hello@coolive.app
EMAIL_FROM_NAME=Coolive

# ── Push (Expo) ───────────────────────────────────────────────────────────
EXPO_PUSH_ACCESS_TOKEN=

# ── Logging ───────────────────────────────────────────────────────────────
# LOG_LEVEL=debug    # default: debug in dev, info in prod
