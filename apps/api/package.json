{
  "name": "@coloc/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts & drizzle-kit studio & wait",
    "build": "tsup src/index.ts --format esm --dts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no linter configured'",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts",
    "db:seed-geo": "tsx src/db/seed-geo.ts",
    "db:seed-amenities": "tsx src/db/seed-amenities.ts",
    "db:seed-images": "tsx src/db/seed-images.ts",
    "db:reattribute-images": "tsx src/db/reattribute-images.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1009.0",
    "@aws-sdk/s3-request-presigner": "^3.1009.0",
    "@better-auth/expo": "^1.6.8",
    "@coloc/contract": "workspace:*",
    "@coloc/shared": "workspace:*",
    "@hono/node-server": "^1",
    "@orpc/server": "^1.13.9",
    "@orpc/zod": "^1.13.9",
    "better-auth": "^1.6.8",
    "dotenv": "^16",
    "drizzle-orm": "^0.41",
    "hono": "^4",
    "hono-pino": "^0.10.3",
    "pg": "^8",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "sharp": "^0.34.5",
    "zod": "^3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/pg": "^8",
    "bcryptjs": "^3.0.3",
    "drizzle-kit": "^0.31",
    "tsup": "^8",
    "tsx": "^4",
    "typescript": "^5.7"
  }
}
