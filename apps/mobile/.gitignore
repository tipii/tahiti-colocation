# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# google-services.json + GoogleService-Info.plist are NOT secret per Google docs.
# They contain restricted API keys + project IDs and are bundled into every APK.
# We commit them so EAS Build (which only uploads git-tracked files) can find them.
#
# The TRULY sensitive file is the service account key (Firebase Admin SDK).
# It contains a private key and grants full Firebase server access — never commit.
*-firebase-adminsdk-*.json
*service-account*.json

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android
